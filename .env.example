# BidPilot 环境变量配置
# 复制此文件为 .env 并根据需要修改

# 运行模式：true=Mock模式(默认), false=真实模型模式
MOCK_MODE=true

# LLM 配置 (Mock模式下不需要配置)
OPENAI_COMPATIBLE_MODE=false
CUSTOM_MODEL_MODE=false
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=deepseek-v4-flash

# 服务配置
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Upload and browser access protection. Use explicit origins in production,
# for example: https://athena-fusion.github.io
CORS_ORIGINS=*
MAX_UPLOAD_SIZE_BYTES=10485760
ANALYSIS_CACHE_MAX_ENTRIES=100

# 前端配置
# 生产构建默认使用静态 Mock 演示；如需连接真实后端，设置为后端 API 根路径，例如 https://api.example.com/api
VITE_API_BASE_URL=

# 数据目录
DATA_DIR=backend/data
OUTPUT_DIR=backend/data/outputs
